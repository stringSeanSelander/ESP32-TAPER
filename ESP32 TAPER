      Serial.println(puffCapture);
      Serial.print("puffStage = ");
      Serial.print(puffStage);
      Serial.print(" puffCount = ");
      Serial.println(puffCount);
      
      if (atomizerButtonVal == 0){
        takePuff();
        stopPuff();
      }
      else {
        stopPuff();
      }
      if (upButtonVal == 0 || downButtonVal == 0){
        if (functionClicked == 0){
          functionSelect = selectFunction();
          functionClicked = 1;
        }
        
      }
      if (functionSelect == 1){
        int taper = selectTaper();
        while (true){
          if (taper == -1){
            functionSelect = 0;
            display.display();
            display.clearDisplay();
            display.display();
            functionClicked = 1;
            delay(1000);
            break;
          }
          Serial.print("taperdelay1");
          bool completed = taperOff(taperSelected, taper);
          functionSelect = 0;
          if (completed == 1){
            taperSelected = false;
            break;
          }
          taperSelected = true;   
        }
        break;
      }
      else if (functionSelect == 2){
        selectTimer();
        functionSelect = 0;
        while (true){
          Serial.println("Looping");
          int vapePower = digitalRead(switchPin);
          int upButtonVal = digitalRead(upButtonPin);
          int downButtonVal = digitalRead(downButtonPin);
          buttonVal = digitalRead(atomizerButtonPin);
          if (upButtonVal == 0){
            beginTimer();
            break;
          }
          if (downButtonVal == 0){
            break;
          }
          if (buttonVal == 0){
            takePuff();
          }
          else if (buttonVal == 1){
            stopPuff();
          }
          if (vapePower == 0){
            setCpuFrequencyMhz(80);
            break;
          }
          
        }
        
      }
      else if (functionSelect == -1){
        clearDisplay();
        break;
      }
      
    }
    break;
  }
  while (vapePower == 0){
    setCpuFrequencyMhz(80);
    clearDisplay();
    while (true){
      vapePower = digitalRead(switchPin);
      Serial.println(vapePower);
      if (vapePower == 1){
        break;
      }
    }
  }
}
